{
  "name": "saihai",
  "version": "0.1.0",
  "description": "Declarative workflow orchestrator for AI agents",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/oda251/sidekick.git"
  },
  "keywords": [
    "ai",
    "agent",
    "workflow",
    "orchestrator",
    "claude"
  ],
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "bin": {
    "saihai": "./dist/cli.js"
  },
  "files": [
    "dist",
    "NOTICE",
    "THIRD_PARTY_LICENSES"
  ],
  "scripts": {
    "dev": "bun src/cli.ts",
    "build": "bun build src/cli.ts --outdir dist --target node --format esm --external @anthropic-ai/claude-agent-sdk",
    "test": "bun test",
    "lint": "oxlint -c oxlintrc.json --type-aware src/ test/",
    "check": "bun test && oxlint -c oxlintrc.json --type-aware src/ test/",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.87",
    "gray-matter": "^4.0.3",
    "nanoid": "^5.1.7",
    "neverthrow": "^8.2.0",
    "valibot": "^1.3.1",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.18.1"
  }
}
