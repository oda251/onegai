{
  "name": "agent-sidekick",
  "version": "0.1.0",
  "description": "Declarative workflow orchestrator for AI agents — MCP server + CLI",
  "type": "module",
  "bin": {
    "sidekick": "./src/cli.ts"
  },
  "scripts": {
    "dev": "bun src/cli.ts serve",
    "start": "bun src/cli.ts serve",
    "test": "bun test",
    "lint": "oxlint -c oxlintrc.json src/ test/",
