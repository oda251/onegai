    "drizzle-valibot": "^0.4.2",
    "gray-matter": "^4.0.3",
    "nanoid": "^5.1.5",
    "neverthrow": "^8.2.0",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10",
    "oxlint": "^1.57.0"
  }
}
